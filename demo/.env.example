# Fail-closed kill switch. Keep false until the Vercel Firewall rate limit and
# every credential/model value below are configured. Only the exact value true
# enables external calls.
DEMO_LIVE_ENABLED=false

# Without complete Fireworks configuration, the API explicitly stays in
# simulation mode and makes zero external calls.
FIREWORKS_API_KEY=your_fireworks_api_key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/your_baseline_model,accounts/fireworks/models/your_answer_model

# Both values must be exact members of ALLOWED_MODELS. If omitted, the server
# chooses only from ALLOWED_MODELS using conservative name-pattern heuristics.
DEMO_BASELINE_MODEL=accounts/fireworks/models/your_baseline_model
DEMO_ANSWER_MODEL=accounts/fireworks/models/your_answer_model

# Optional safeguards for provider output. Defaults: 16 and 500.
DEMO_BASELINE_MAX_TOKENS=16
DEMO_ANSWER_MAX_TOKENS=500
