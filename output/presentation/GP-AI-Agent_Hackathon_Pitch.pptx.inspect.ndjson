{"kind":"textbox","id":"sh/tovahoza","slide":2,"text":"Some tasks can be solved locally and verified deterministically in the container.","textPreview":"Some tasks can be solved locally and verified deterministically in the container.","textChars":81,"textLines":1,"bbox":[130,432,459,66]}
